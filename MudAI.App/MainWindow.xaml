<Window x:Class="MudAI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MudAI.App"
        mc:Ignorable="d"
        Title="MudAI - Telnet MUD AI Client"
        Height="820" Width="1200" MinHeight="560" MinWidth="900"
        Background="{StaticResource BgBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <local:InverseBooleanToVisibilityConverter x:Key="InvBoolVis" />
        <FontFamily x:Key="Mono">Consolas, Cascadia Mono, Courier New</FontFamily>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Connection bar ===== -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Connect" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ConnectCommand}" Margin="0,0,8,0" />
                <Button Content="Disconnect" Command="{Binding DisconnectCommand}" />

                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="16,0,6,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="12,0,0,0"><Run Text="Server: " /><Run Text="{Binding Host}" /><Run Text=":" /><Run Text="{Binding Port}" /></TextBlock>

                <Button Content="Test LM Studio" Command="{Binding PingLlmCommand}" Margin="24,0,8,0" />
                <TextBlock Text="{Binding LlmStatus}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />

                <Button Content="Settings" Click="OpenSettings_Click" Margin="24,0,0,0" />
            </StackPanel>
        </Border>

        <!-- ===== Busy indicator (1s-10s indeterminate feedback) ===== -->
        <ProgressBar Grid.Row="1" Style="{StaticResource BusyBar}" Margin="0,0,0,6"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                     AutomationProperties.Name="Working" />

        <!-- ===== Main split: terminal | AI panel ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="420" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <!-- Terminal column -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <RichTextBox x:Name="TerminalBox"
                                     IsReadOnly="True" IsReadOnlyCaretVisible="False"
                                     Background="{StaticResource TerminalBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderThickness="0"
                                     FontFamily="{StaticResource Mono}" FontSize="13"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     AutomationProperties.Name="MUD output">
                            <RichTextBox.Resources>
                                <Style TargetType="Paragraph">
                                    <Setter Property="Margin" Value="0" />
                                </Style>
                            </RichTextBox.Resources>
                        </RichTextBox>

                        <!-- empty state -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False"
                                    Visibility="{Binding HasTerminalContent, Converter={StaticResource InvBoolVis}}">
                            <TextBlock Text="No output yet" Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Set a host and port, then Connect to begin."
                                       Style="{StaticResource HintText}" HorizontalAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- live prompt (rendered with its real ANSI colours in code-behind) -->
                    <TextBlock x:Name="PromptBox" Grid.Row="1" Margin="6,6,6,4"
                               FontFamily="{StaticResource Mono}" Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" AutomationProperties.Name="{Binding CurrentPrompt}" />

                    <!-- manual command line -->
                    <Grid Grid.Row="2" Margin="4,0,4,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Content="Command" Target="{Binding ElementName=CommandBox}" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="CommandBox"
                                     Text="{Binding ManualCommand, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource Mono}"
                                     AutomationProperties.Name="Command to send"
                                     ToolTip="Type a command and press Enter to send it to the MUD yourself.">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SendManualCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="Send" Command="{Binding SendManualCommand}" Margin="8,0,0,0" />
                            <Button Grid.Column="2" Content="Clear" Command="{Binding ClearTranscriptCommand}" Margin="8,0,0,0" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent"
                          AutomationProperties.Name="Resize panels" />

            <!-- AI panel column -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,12,0">
                        <!-- AI control -->
                        <TextBlock Text="AI CONTROL" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,4" />
                        <CheckBox IsChecked="{Binding AiEnabled}" FontWeight="SemiBold"
                                  Content="AI may send commands (master switch)" />
                        <TextBlock Text="When off, you drive the MUD by hand. Turn on once you are logged in."
                                   Style="{StaticResource HintText}" Margin="0,4,0,8" />
                        <Label Content="Autonomy mode" Target="{Binding ElementName=ModeBox}" />
                        <ComboBox x:Name="ModeBox" ItemsSource="{Binding AutonomyModes}"
                                  SelectedItem="{Binding SelectedMode}" AutomationProperties.Name="Autonomy mode" />

                        <!-- Goal -->
                        <TextBlock Text="GOAL" Style="{StaticResource SectionHeaderText}" />
                        <TextBox Text="{Binding Goal, UpdateSourceTrigger=LostFocus}" TextWrapping="Wrap"
                                 AcceptsReturn="True" MinHeight="36" AutomationProperties.Name="Agent goal"
                                 ToolTip="The agent's current short-term goal. You and the AI can both edit it." />

                        <!-- Steering -->
                        <TextBlock Text="LIVE STEERING" Style="{StaticResource SectionHeaderText}" />
                        <TextBox Text="{Binding Steering, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap"
                                 AcceptsReturn="True" MinHeight="48" AutomationProperties.Name="Live steering"
                                 ToolTip="Real-time guidance fed into every turn until you change or clear it." />
                        <Button Content="Clear steering" Command="{Binding ClearSteeringCommand}"
                                HorizontalAlignment="Left" Margin="0,6,0,0" />

                        <!-- Game state -->
                        <TextBlock Text="GAME STATE (GMCP / MSDP)" Style="{StaticResource SectionHeaderText}" />
                        <TextBlock Text="{Binding GameStateText}" Foreground="{StaticResource SuccessBrush}"
                                   TextWrapping="Wrap" FontFamily="{StaticResource Mono}" FontSize="12" />

                        <!-- Approval -->
                        <Border Margin="0,12,0,0" Padding="10" CornerRadius="6"
                                Background="#1F2A2233" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                                Visibility="{Binding HasPendingApproval, Converter={StaticResource BoolVis}}">
                            <StackPanel>
                                <TextBlock Text="Approval needed" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Text="{Binding PendingReasoning}" TextWrapping="Wrap" Margin="0,4,0,4" />
                                <TextBlock Style="{StaticResource CaptionText}"><Run Text="Risk: " /><Run Text="{Binding PendingRisk}" /></TextBlock>
                                <Label Content="Command to send" Target="{Binding ElementName=PendingBox}" Margin="0,6,0,0" />
                                <TextBox x:Name="PendingBox" Text="{Binding PendingCommand, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource Mono}" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Content="Approve and send" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ApproveCommand}" Margin="0,0,8,0" />
                                    <Button Content="Reject" Command="{Binding RejectCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Live model output -->
                        <TextBlock Text="LIVE MODEL OUTPUT" Style="{StaticResource SectionHeaderText}" />
                        <Border Background="{StaticResource TerminalBrush}" BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="6" MinHeight="64" MaxHeight="120">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding LiveResponse}" TextWrapping="Wrap" Margin="8"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontFamily="{StaticResource Mono}" FontSize="12" />
                                </ScrollViewer>
                                <TextBlock Text="The model's output appears here as it is generated."
                                           Margin="8"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource HintText}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LiveResponse}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Reasoning feed -->
                        <TextBlock Text="AI REASONING" Style="{StaticResource SectionHeaderText}" />
                        <Grid MinHeight="120">
                            <ListBox x:Name="ReasoningList" ItemsSource="{Binding ReasoningLog}"
                                     Background="{StaticResource SurfaceAltBrush}" MaxHeight="240"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     AutomationProperties.Name="AI reasoning log">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="The AI's reasoning for each turn will show here once it starts playing."
                                       Style="{StaticResource HintText}" Margin="8" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="{Binding HasItems, ElementName=ReasoningList, Converter={StaticResource InvBoolVis}}" />
                        </Grid>

                        <!-- Anti-loop -->
                        <TextBlock Text="ANTI-LOOP (SUPPRESSED)" Style="{StaticResource SectionHeaderText}" />
                        <Grid MinHeight="56">
                            <ListBox x:Name="SuppressionsList" ItemsSource="{Binding Suppressions}"
                                     Background="{StaticResource SurfaceAltBrush}" MaxHeight="110"
                                     AutomationProperties.Name="Suppressed commands">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource DangerBrush}" Margin="0,1"><Run Text="blocked: " /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="No commands are being suppressed."
                                       Style="{StaticResource HintText}" Margin="8" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="{Binding HasItems, ElementName=SuppressionsList, Converter={StaticResource InvBoolVis}}" />
                        </Grid>

                        <TextBlock Text="{Binding MemoryStats}" Style="{StaticResource CaptionText}" Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="10,6" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" />
        </Border>
    </Grid>
</Window>
