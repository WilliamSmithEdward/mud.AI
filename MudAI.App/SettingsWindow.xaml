<Window x:Class="MudAI.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="440" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource BgBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI" FontSize="14">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Settings" Style="{StaticResource TitleText}" Margin="0,0,0,12" />

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="CONNECTION" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,4" />
                    <Label Content="Host" Target="{Binding ElementName=HostBox}" />
                    <TextBox x:Name="HostBox" Text="{Binding Host}" AutomationProperties.Name="MUD host" />
                    <Label Content="Port" Target="{Binding ElementName=PortBox}" Margin="0,8,0,0" />
                    <TextBox x:Name="PortBox" Text="{Binding Port}" Width="120" HorizontalAlignment="Left"
                             AutomationProperties.Name="MUD port" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="AUTO-LOGIN" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,4" />
                    <CheckBox IsChecked="{Binding AutoLogin}" Content="Auto-login on connect" Margin="0,0,0,8" />
                    <Label Content="Username" Target="{Binding ElementName=UserBox}" />
                    <TextBox x:Name="UserBox" Text="{Binding LoginUsername, UpdateSourceTrigger=LostFocus}"
                             AutomationProperties.Name="Login username" />
                    <Label Content="Password" Target="{Binding ElementName=PasswordBox}" Margin="0,8,0,0" />
                    <PasswordBox x:Name="PasswordBox" AutomationProperties.Name="Login password" />
                    <TextBlock Text="The password is entered here only and is never written to config or shown to the model."
                               Style="{StaticResource HintText}" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Button Content="Done" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                    IsDefault="True" Click="Done_Click" />
        </StackPanel>
    </Grid>
</Window>
